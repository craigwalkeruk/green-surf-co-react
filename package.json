{
  "name": "bulletproof-react-vite",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --base=/",
    "preview": "vite preview",
    "test": "vitest",
    "test-e2e": "playwright test",
    "test-vrt": "vitest --config config/vitest.config.vrt.ts",
    "test-vrt:watch": "vitest --config config/vitest.config.vrt.ts --watch",
    "test-vrt-docker": "docker build -f Dockerfile.vrt -t bulletproof-vrt . && docker run --rm -v \"$PWD\":/app -v /app/node_modules bulletproof-vrt 2>&1",
    "test-vrt-docker:build": "docker build -f Dockerfile.vrt -t bulletproof-vrt .",
    "test-vrt-docker:watch": "docker run --rm -it -v \"$(pwd)\":/app -v /app/node_modules bulletproof-vrt yarn test-vrt-docker-run -- --watch",
    "test-vrt-docker-run": "vitest --config config/vitest.config.vrt.docker.ts",
    "test-vrt:report": "npx tsx src/test/generate-vrt-report.ts",
    "prepare": "husky",
    "check-types": "tsc --project tsconfig.json --pretty --noEmit",
    "storybook": "EDITOR=webstorm storybook dev -p 6006",
    "build-storybook": "storybook build",
    "run-mock-server": "npx tsx src/mocks/mock-server.ts | pino-pretty -c"
  },
  "dependencies": {
    "@github/copilot-language-server": "^1.440.0",
    "@hookform/resolvers": "^3.3.4",
    "@ngneat/falso": "^7.2.0",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@tanstack/react-query": "^5.32.0",
    "@tanstack/react-query-devtools": "^5.32.0",
    "axios": "^1.6.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "dompurify": "^3.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^1.0.0",
    "marked": "^12.0.2",
    "nanoid": "^5.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^4.0.13",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.51.3",
    "react-query-auth": "^2.4.3",
    "react-router": "^7.0.2",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@mswjs/data": "^0.16.2",
    "@mswjs/http-middleware": "^0.10.1",
    "@playwright/test": "^1.43.1",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-links": "^10.2.16",
    "@storybook/addon-mcp": "^0.3.2",
    "@storybook/react": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@tailwindcss/typography": "^0.5.13",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/cors": "^2.8.17",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.12.7",
    "@types/pixelmatch": "^5.2.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/browser-playwright": "^4.1.0",
    "autoprefixer": "^10.4.19",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "husky": "^9.0.11",
    "js-cookie": "^3.0.5",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.2",
    "msw": "^2.2.14",
    "pino-http": "^10.1.0",
    "pino-pretty": "^11.1.0",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.43.1",
    "plop": "^4.0.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "storybook": "^10.2.16",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0",
    "vitest-browser-react": "^0.1.0"
  },
  "overrides": {
    "@mswjs/data": {
      "uuid": "^14.0.0"
    },
    "@ngneat/falso": {
      "uuid": "^14.0.0"
    }
  },
  "msw": {
    "workerDirectory": "public"
  },
  "lint-staged": {
    "*.+(ts|tsx)": [
      "npm run lint",
      "bash -c 'npm run check-types'"
    ]
  }
}
