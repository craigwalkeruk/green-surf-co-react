FROM mcr.microsoft.com/playwright:v1.58.2-noble

WORKDIR /app

ENV NPM_CONFIG_PROGRESS=false
ENV FORCE_COLOR=1

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm ci

# Copy source files
COPY . .

# Run VRT tests in headless mode
CMD ["npm", "run", "test-vrt-docker-run"]
